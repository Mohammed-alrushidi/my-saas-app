{
  "$schema": "https://opencode.ai/config.json",
  "model": "nvidia/z-ai/glm-5.2",
  "instructions": ["AGENTS.md"],
  "permission": {
    "skill": "allow"
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "shadcn@latest", "mcp"],
      "enabled": true
    }
  }
}
