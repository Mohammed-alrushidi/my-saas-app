# ──────────────────────────────────────────────
# Supabase (required for local dev and deployment)
# ──────────────────────────────────────────────
# Create a project at https://supabase.com
# Copy these from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is a server-only secret. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────
# Live WhatsApp safety gate
# ──────────────────────────────────────────────
# MOCK_MODE=true uses the mock provider and ignores these values.
# Real sending requires BOTH:
#   MOCK_MODE=false
#   WHATSAPP_LIVE_ENABLED=true
# And valid Twilio credentials below.
WHATSAPP_LIVE_ENABLED=false

# ──────────────────────────────────────────────
# Twilio WhatsApp (required for sending messages)
# ──────────────────────────────────────────────
# Required only when live WhatsApp sending is enabled.
# Set these in your hosting environment (Vercel) for production.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Sandbox number; replace with your WABA number in production
TWILIO_WHATSAPP_NUMBER=+141****8886

# ──────────────────────────────────────────────
# Site URL (required for password reset emails and delivery status callbacks)
# ──────────────────────────────────────────────
# SITE_URL is server-side only (used for Twilio status callbacks).
# NEXT_PUBLIC_SITE_URL is available to both client and server (used for password reset redirect).
# Set both to your deployed URL in production.
# Localhost defaults are used if these are unset.
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Cron / Scheduler (required for automated reminders)
# ──────────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
# This protects the /api/cron/scheduler endpoint from unauthorized invocations.
CRON_SECRET=your-random-cron-secret
